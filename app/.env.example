# 이 파일을 .env 로 복사해서 채운다. .env 는 커밋하지 않는다.
# 여기 있는 값은 전부 클라이언트 번들에 포함된다 — 비밀을 넣지 마라.
# 공공데이터포털 serviceKey 는 proxy/.env 에 있다. (그것이 프록시가 존재하는 이유다)

# ─────────────────────────────────────────────────────────────
# 발급이 필요한 것
# ─────────────────────────────────────────────────────────────

# [Kakao Developers] JavaScript 키 — 지도 폴백 ①
#   발급: developers.kakao.com > 애플리케이션 추가 > 앱 키 > JavaScript 키
#   필수: 플랫폼 > Web > 사이트 도메인에 토스 WebView origin 등록 (미등록 시 SDK 미로드)
#   JS 키는 클라이언트 노출이 정상이다. 반드시 도메인 제한을 걸 것.
#   비우면 지도 폴백이 ②Leaflet 부터 시작한다.
VITE_KAKAO_JS_KEY=

# [VWorld] 타일 URL — 지도 폴백 ②. 프로덕션에서 필수.
#   발급: vworld.kr > 오픈API > 인증키 발급 (활용 URL 등록)
#   예: https://api.vworld.kr/req/wmts/1.0.0/{발급키}/Base/{z}/{y}/{x}.png
#
#   OSM 공개 타일(tile.openstreetmap.org)은 상용·대량 트래픽 사용이 금지되어 있다
#   (OSMF Tile Usage Policy). 전국 MAU 목표와 충돌한다.
#   비우면 지도 ②를 건너뛰고 리스트 UI(③)로 내려간다 — 조용히 위반하지 않는다.
#   (개발 모드에서만 OSM 타일을 쓴다.)
VITE_TILE_URL=
VITE_TILE_ATTRIBUTION=

# ─────────────────────────────────────────────────────────────
# 발급 불필요 — 배포하고 나서 채우는 값
# ─────────────────────────────────────────────────────────────

# 서버리스 프록시 베이스 URL (예: https://shimpyo-proxy.vercel.app)
# 비워두면 목 데이터로 동작하고, 화면 상단에 "예시 데이터예요" 배너가 뜬다.
# 이 값이 채워지는 순간 실데이터 모드로 전환된다.
VITE_PROXY_BASE=

# 시군구 JSON이 호스팅된 CDN 베이스. 비워두면 앱의 /data 를 쓴다(개발용).
VITE_DATA_BASE=

# 제보용 외부 폼 URL (구글 폼 등). 비워두면 제보 버튼이 숨겨진다.
VITE_REPORT_FORM_URL=

# 개인정보 처리방침 URL. 콘솔 심사 제출물. 비워두면 링크가 숨겨진다.
VITE_PRIVACY_POLICY_URL=
